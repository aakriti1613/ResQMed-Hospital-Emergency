# Required for production (Firebase Hosting + Auth + Firestore)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: FCM web push
# VITE_FIREBASE_VAPID_KEY=

# Browser Maps / Places (restrict this key in GCP for your domains only)
VITE_GOOGLE_MAPS_API_KEY=

# Google Pay (see src/lib/googlePay.ts)
# VITE_GOOGLE_PAY_ENV=TEST
# VITE_GOOGLE_PAY_MERCHANT_ID=
# VITE_GOOGLE_PAY_MERCHANT_NAME=
# VITE_GOOGLE_PAY_GATEWAY=
# VITE_GOOGLE_PAY_GATEWAY_MERCHANT_ID=

# Optional: Cloud Functions base URL (local emulator: http://127.0.0.1:5001)
# VITE_FUNCTIONS_ORIGIN=

# Optional: ML crash severity API (local only — omit in production unless hosted)
# VITE_ML_SEVERITY_URL=http://127.0.0.1:8001/predict/severity
